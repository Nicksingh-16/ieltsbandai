APP_NAME=IeltsBandAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
# For local development, use MySQL
# For production, use your hosting provider's database (Railway MySQL, PlanetScale, etc.)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ieltsbandai
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — prod uses Resend (https://resend.com). The "log" default below keeps
# local dev quiet; flip to "resend" + set RESEND_API_KEY in production env.
# MAIL_FROM_ADDRESS must be on a verified Resend domain (or use the shared
# onboarding@resend.dev sender while you verify your own domain).
MAIL_MAILER=log
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=PUT_RESEND_KEY_HERE

# ─────────────────────────────────────────────────────────────────
# Sentry — error tracking (https://sentry.io)
# ─────────────────────────────────────────────────────────────────
# Leave blank in dev. In prod, paste the DSN from your Sentry project
# (Settings → Projects → <project> → Client Keys (DSN)).
# Traces: 0.0 disables performance monitoring (keeps the free-tier quota
# in budget). Bump to 0.1 once you want span-level latency data.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Enable detailed debug logs (disable in production)
IELTS_DEBUG=true

# Transcription Provider (choose 'assemblyai' or 'deepgram')
TRANSCRIPTION_PROVIDER=assemblyai

# Deepgram API (if using Deepgram for speech-to-text)
# Get your API key from: https://console.deepgram.com/
DEEPGRAM_API_KEY=PUT_DEEPGRAM_KEY_HERE

# AssemblyAI API (if using AssemblyAI for speech-to-text)
# Get your API key from: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=PUT_ASSEMBLYAI_KEY_HERE

# ─────────────────────────────────────────────────────────────────
# LLM Provider chain: OpenRouter → OpenAI → Groq → Gemini
# ─────────────────────────────────────────────────────────────────
# OpenRouter tier activates when OPENROUTER_API_KEY starts with 'sk-or-'.
# It's a paid passthrough to OpenAI/Anthropic/etc. that accepts UPI billing.
# Three layers of cost protection:
#   1. OpenRouter dashboard: account credit balance + per-key credit limit
#   2. LLM_OPENROUTER_DAILY_USD_CAP / TOTAL_USD_CAP: app-side cutoff that
#      sums llm_call_logs.cost_usd and skips this tier once exceeded
#   3. Auto top-up OFF + no payment method saved → physical ceiling
#
# Leave caps blank to disable the app-side guard (rely on dashboard only).
OPENROUTER_API_KEY=PUT_OPENROUTER_SK_OR_KEY_HERE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/
OPENROUTER_MODEL=openai/gpt-4o-mini
# Beta sizing: ~$0.005-0.01 per full scoring call on mini. $2/day covers
# ~200-400 evaluations before fallback chain kicks in (Groq → Gemini, free).
LLM_OPENROUTER_DAILY_USD_CAP=2.00
LLM_OPENROUTER_TOTAL_USD_CAP=20.00

# OpenAI tier activates only when OPENAI_API_KEY starts with 'sk-' (and
# is NOT an OpenRouter sk-or- key). For direct OpenAI billing — needs
# international card. Most setups use OpenRouter above instead.
OPENAI_API_KEY=PUT_OPENAI_SK_KEY_HERE
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_MODEL=gpt-4o-mini

# Gemini key pool for round-robin + Pro→Flash fallback
# Each key gives: 50 Pro req/day + 1500 Flash req/day (separate quotas)
GEMINI_API_KEY_1=PUT_GEMINI_KEY_1_HERE
GEMINI_API_KEY_2=PUT_GEMINI_KEY_2_HERE
GEMINI_API_KEY_3=PUT_GEMINI_KEY_3_HERE
GEMINI_API_KEY_4=PUT_GEMINI_KEY_4_HERE
GEMINI_API_KEY_5=PUT_GEMINI_KEY_5_HERE
GEMINI_PRIMARY_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Legacy single-key Gemini var, used by the older GeminiService for
# vocabulary / clarification calls. New scoring path uses the pool above.
GEMINI_API_KEYS=PUT_GEMINI_KEY_1_HERE

# Groq (PRIMARY LLM provider). Free tier: 14,400 req/day, no card required.
# Sign up at https://console.groq.com/ and grab a key.
# Llama 3.3 70B Versatile via OpenAI-compatible endpoint.
GROQ_API_KEY=PUT_GROQ_KEY_HERE
GROQ_BASE_URL=https://api.groq.com/openai/v1/
GROQ_MODEL=llama-3.3-70b-versatile

# Razorpay Payment Gateway (for Indian payments — activates once a verified
# domain is attached. While inactive, the manual UPI flow below is the
# primary paywall path.)
RAZORPAY_KEY=PUT_RAZORPAY_KEY_ID_HERE
RAZORPAY_SECRET=PUT_RAZORPAY_SECRET_HERE
RAZORPAY_WEBHOOK_SECRET=PUT_RAZORPAY_WEBHOOK_SECRET_HERE

# ─────────────────────────────────────────────────────────────────
# Manual UPI Payment (beta paywall)
# ─────────────────────────────────────────────────────────────────
# The paywall generates a UPI deep-link QR pointing at this VPA. Users pay,
# submit their UTR, we trust-then-verify (auto-grant credits, manual UTR
# audit out-of-band via bank statement). Refund flow is admin-only.
UPI_VPA=your-name@bankhandle
UPI_NAME="IELTS Band AI"
# Where new payment notifications land (admin inbox). Leave blank to disable.
UPI_NOTIFY_EMAIL=

# ─────────────────────────────────────────────────────────────────
# Beta Mode (single switch — see config/beta.php)
# ─────────────────────────────────────────────────────────────────
# When true: bumps signup credits, shows "Beta — feedback" banner,
# captures ?ref= UTM tag on landing, and hides the paid Razorpay CTA.
# Set to false at go-live; no code changes needed.
BETA_MODE=false
BETA_SIGNUP_CREDITS=8
BETA_FEEDBACK_URL=
BETA_BANNER_TEXT="You're using IELTS Band AI Beta. Found a bug or have feedback?"
BETA_PAY_REPLACEMENT="Pro plans launching soon — leave feedback to get early access"
BETA_DISABLE_GOOGLE_OAUTH=true

# Google OAuth (for social login)
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=PUT_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=PUT_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

VITE_APP_NAME="${APP_NAME}"

# Layer 3 calibration toggle: set to false to capture a no-few-shot baseline
# benchmark for A/B comparison. Default true in production.
FEW_SHOT_ENABLED=true

# L5-v2 piecewise upward bias correction. Tuned against gpt-4o-mini on a
# 10-essay holdout. SAFE for mini (the primary OpenRouter tier above).
# When fallback drops to Groq Llama or Gemini Flash, the bias profile is
# different — over-correction may push scores too high at low/mid bands.
# Disable temporarily if you observe consistent over-scoring during free-tier
# fallback. Re-tune per provider once each has its own holdout.
BIAS_CORRECTION_ENABLED=true
